# ─────────────────────────────────────────────────────────────────
# AI OpsBMC — Example Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────

# ── BMC Connection ────────────────────────────────────────────────
BMC_HOST=localhost
BMC_PORT=8080
BMC_USERNAME=admin
BMC_PASSWORD=admin
BMC_USE_SSL=false
# For real BMCs with self-signed certs:
# BMC_VERIFY_SSL=false
# BMC_CA_CERT=/etc/ssl/certs/bmc-ca.pem

# ── Database ──────────────────────────────────────────────────────
# SQLite (development/testing)
DATABASE_URL=sqlite:///./telemetry/db/telemetry.db

# PostgreSQL (production) - uncomment and configure:
# DATABASE_URL=postgresql://aiobmc:securepassword@postgres:5432/aiobmc

# ── Security ──────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=change-this-to-a-random-64-character-string-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ── Telemetry Collection ──────────────────────────────────────────
COLLECTION_INTERVAL_SECONDS=30
ANOMALY_THRESHOLD=0.5

# ── Health Score Thresholds ───────────────────────────────────────
HEALTH_WARN_THRESHOLD=60
HEALTH_CRITICAL_THRESHOLD=40

# ── Remediation ───────────────────────────────────────────────────
APPROVAL_TIMEOUT_MINUTES=15
ROLLBACK_HEALTH_DELTA=5

# ── LLM (Diagnosis Generation) ────────────────────────────────────
# OpenAI (cloud):
# OPENAI_API_KEY=sk-your-openai-api-key-here
# LLM_MODEL=gpt-4o-mini

# Local (Ollama):
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=llama3.2

# ── Observability ─────────────────────────────────────────────────
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_PASSWORD=admin

# ── Service Ports ─────────────────────────────────────────────────
DASHBOARD_PORT=8000
COLLECTOR_PORT=8001
ANALYTICS_PORT=8002
AGENT_PORT=8003

# ── Logging ───────────────────────────────────────────────────────
LOG_LEVEL=INFO
# LOG_LEVEL=DEBUG  # for verbose output
